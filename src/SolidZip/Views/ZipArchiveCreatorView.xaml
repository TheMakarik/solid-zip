<Window
    AllowsTransparency="True"
    Background="{DynamicResource BackgroundColorBrush}"
    DataContext="{markupExtensions:ResolveViewAndViewModel}"
    Height="550"
    Icon="/assets/szicon.ico"
    MinHeight="450"
    MinWidth="600"
    MouseLeftButtonDown="DragWindow"
    ResizeMode="CanResizeWithGrip"
    Title="{Binding Localization.NewZip, Mode=OneWay}"
    Width="800"
    WindowStyle="None"
    d:DataContext="{d:DesignInstance viewModels:ZipArchiveCreatorViewModel}"
    mc:Ignorable="d"
    x:Class="SolidZip.Views.ZipArchiveCreatorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:markupExtensions="clr-namespace:SolidZip.Views.MarkupExtensions"
    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:SolidZip.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Title bar  -->
        <Border
            Background="{DynamicResource BackgroundColorBrush}"
            BorderBrush="{DynamicResource ForegroundColorBrush}"
            BorderThickness="0,0,0,1"
            Grid.Row="0"
            Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <Image
                        Height="24"
                        Margin="0,0,10,0"
                        Source="../assets/szicon.ico"
                        Width="24" />
                    <TextBlock
                        FontFamily="{StaticResource BricolageGrotesque}"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource ForegroundColorBrush}"
                        Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" />
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <Button
                        Click="Minimize"
                        Margin="0,0,5,0"
                        Style="{StaticResource SzIconButton}"
                        ToolTip="{Binding Localization.Minimize, Mode=OneWay}">
                        <materialIcons:MaterialIcon Foreground="{DynamicResource ForegroundColorBrush}" Kind="Minimize" />
                    </Button>
                    <Button
                        Click="Restore"
                        Margin="0,0,5,0"
                        Style="{StaticResource SzIconButton}"
                        ToolTip="{Binding Localization.Maximize, Mode=OneWay}">
                        <materialIcons:MaterialIcon Foreground="{DynamicResource ForegroundColorBrush}" Kind="Maximize" />
                    </Button>
                    <Button
                        Click="Close"
                        Style="{StaticResource SzIconButton}"
                        ToolTip="{Binding Localization.Close, Mode=OneWay}">
                        <materialIcons:MaterialIcon Foreground="{DynamicResource ForegroundColorBrush}" Kind="Close" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  Main Content  -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Left Column - Files Selection  -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Foreground="{DynamicResource ForegroundColorBrush}"
                    Grid.Row="0"
                    Margin="0,0,0,10"
                    Style="{StaticResource SzTextBlockSectionHeader}"
                    Text="{Binding Localization.FilesToAdd, Mode=OneWay}" />

                <Border
                    BorderBrush="{DynamicResource ForegroundColorBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Grid.Row="1"
                    Margin="0,0,0,10">
                    <ListBox
                        Background="{DynamicResource BackgroundColorBrush}"
                        BorderBrush="{DynamicResource ForegroundColorBrush}"
                        ItemsSource="{Binding FilesToAdd}"
                        Style="{StaticResource SzFilesSettingsListBox}">
                        <ListBox.ItemContainerStyle>
                            <Style BasedOn="{StaticResource SzListBoxItemSettings}" TargetType="ListBoxItem">
                                <Setter Property="Tag" Value="{Binding RelativeSource={RelativeSource AncestorType=ListBox}}" />
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu
                                            Background="{DynamicResource BackgroundColorBrush}"
                                            BorderBrush="Transparent"
                                            Style="{StaticResource SzContextMenu}">
                                            <MenuItem
                                                Command="{Binding Tag.DataContext.RemoveFileCommand}"
                                                CommandParameter="{Binding}"
                                                Foreground="{DynamicResource ForegroundColorBrush}"
                                                Header="{Binding Tag.DataContext.Localization.Remove, Mode=OneWay}"
                                                Icon="{materialIcons:MaterialIconExt Kind=Close}"
                                                Style="{StaticResource SzMenuItem}" />
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>

                <StackPanel
                    Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        Command="{Binding AddFilesCommand}"
                        Margin="0,0,5,0"
                        Style="{StaticResource SzIconButton}"
                        ToolTip="{Binding Localization.AddFiles, Mode=OneWay}">
                        <materialIcons:MaterialIcon Foreground="{DynamicResource ForegroundColorBrush}" Kind="FilePlus" />
                    </Button>
                    <Button
                        Command="{Binding AddFolderCommand}"
                        Margin="0,0,5,0"
                        Style="{StaticResource SzIconButton}"
                        ToolTip="{Binding Localization.AddFolder, Mode=OneWay}">
                        <materialIcons:MaterialIcon Foreground="{DynamicResource ForegroundColorBrush}" Kind="FolderPlus" />
                    </Button>
                    <Button
                        Command="{Binding ClearFilesCommand}"
                        IsEnabled="{Binding FilesToAdd.Count, Mode=OneWay, Converter={markupExtensions:Converters Converter=CountToBooleanConverter}}"
                        Style="{StaticResource SzIconButton}"
                        ToolTip="{Binding Localization.ClearAll, Mode=OneWay}">
                        <materialIcons:MaterialIcon Foreground="{DynamicResource ForegroundColorBrush}" Kind="CloseCircle" />
                    </Button>
                </StackPanel>
            </Grid>

            <!--  Separator  -->
            <Border
                Background="{DynamicResource ForegroundColorBrush}"
                Grid.Column="1"
                Margin="0,20"
                Width="1" />

            <!--  Right Column - Archive Settings  -->
            <ScrollViewer
                Grid.Column="2"
                Margin="10,0,0,0"
                VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock
                        Foreground="{DynamicResource ForegroundColorBrush}"
                        Margin="0,0,0,15"
                        Style="{StaticResource SzTextBlockSectionHeader}"
                        Text="{Binding Localization.ArchiveSettings, Mode=OneWay}" />

                    <!--  Output Folder  -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock
                            Foreground="{DynamicResource ForegroundColorBrush}"
                            Margin="0,0,0,5"
                            Style="{StaticResource SzTextBlockLabel}"
                            Text="{Binding Localization.OutputFolder, Mode=OneWay}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <materialIcons:MaterialIcon
                                Foreground="{DynamicResource ForegroundColorBrush}"
                                Grid.Column="0"
                                Height="20"
                                Kind="Folder"
                                Margin="0,0,10,5"
                                Width="20" />

                            <TextBox
                                Background="{DynamicResource BackgroundColorBrush}"
                                BorderBrush="{DynamicResource ForegroundColorBrush}"
                                Foreground="{DynamicResource ForegroundColorBrush}"
                                Grid.Column="1"
                                IsReadOnly="True"
                                Margin="0,0,5,0"
                                Style="{StaticResource SzTextBox}"
                                Text="{Binding ArchivePath}"
                                ToolTip="{Binding ArchivePath}" />

                            <Button
                                Command="{Binding SelectOutputFolderCommand}"
                                Grid.Column="2"
                                Padding="8,5"
                                Style="{StaticResource SzIconButton}">
                                <materialIcons:MaterialIcon Foreground="{DynamicResource ForegroundColorBrush}" Kind="FolderOpen" />
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!--  Archive Name  -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock
                            Foreground="{DynamicResource ForegroundColorBrush}"
                            Margin="0,0,0,5"
                            Style="{StaticResource SzTextBlockLabel}"
                            Text="{Binding Localization.ArchiveName, Mode=OneWay}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <materialIcons:MaterialIcon
                                Foreground="{DynamicResource ForegroundColorBrush}"
                                Grid.Column="0"
                                Height="20"
                                Kind="Rename"
                                Margin="0,0,10,5"
                                Width="20" />

                            <TextBox
                                Grid.Column="1"
                                Style="{StaticResource SzTextBox}"
                                Text="{Binding ArchiveName}" />
                        </Grid>
                    </StackPanel>

                    <!--  Encryption Settings  -->
                    <Border
                        Background="{DynamicResource BackgroundColorBrush}"
                        BorderBrush="{DynamicResource ForegroundColorBrush}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Margin="0,0,0,15"
                        Padding="10">
                        <StackPanel>
                            <TextBlock
                                Foreground="{DynamicResource ForegroundColorBrush}"
                                Margin="0,0,0,10"
                                Style="{StaticResource SzTextBlockLabel}"
                                Text="{Binding Localization.Encryption, Mode=OneWay}" />

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <materialIcons:MaterialIcon
                                    Foreground="{DynamicResource ForegroundColorBrush}"
                                    Grid.Column="0"
                                    Height="20"
                                    Kind="Shield"
                                    Margin="0,0,10,5"
                                    Width="20" />

                                <ComboBox
                                    Background="{DynamicResource BackgroundColorBrush}"
                                    BorderBrush="{DynamicResource ForegroundColorBrush}"
                                    Foreground="{DynamicResource BackgroundColorBrush}"
                                    Grid.Column="1"
                                    ItemsSource="{Binding EncryptionOptions}"
                                    SelectedItem="{Binding Encryption}"
                                    Style="{StaticResource SzComboBox}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Foreground="{DynamicResource BackgroundColorBrush}" Text="{Binding Converter={markupExtensions:Converters Converter=EnumToLocalizedStringConverter}, Mode=OneWay}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <materialIcons:MaterialIcon
                                    Foreground="{DynamicResource ForegroundColorBrush}"
                                    Grid.Column="0"
                                    Height="20"
                                    Kind="Lock"
                                    Margin="0,0,10,0"
                                    Opacity="{Binding IsPasswordEnabled, Mode=OneWay, Converter={markupExtensions:Converters Converter=BooleanToOpacityConverter}}"
                                    Width="20" />

                                <TextBox
                                    Background="{DynamicResource BackgroundColorBrush}"
                                    BorderBrush="{DynamicResource ForegroundColorBrush}"
                                    Foreground="{DynamicResource ForegroundColorBrush}"
                                    Grid.Column="1"
                                    IsEnabled="{Binding IsPasswordEnabled}"
                                    Style="{StaticResource SzTextBox}"
                                    Text="{Binding Password}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!--  Summary  -->
                    <Border
                        Background="{DynamicResource BackgroundColorBrush}"
                        BorderBrush="{DynamicResource ForegroundColorBrush}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="10">
                        <StackPanel>
                            <TextBlock
                                Foreground="{DynamicResource ForegroundColorBrush}"
                                Margin="0,0,0,10"
                                Style="{StaticResource SzTextBlockLabel}"
                                Text="{Binding Localization.Summary, Mode=OneWay}" />

                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <materialIcons:MaterialIcon
                                    Foreground="{DynamicResource ForegroundColorBrush}"
                                    Grid.Column="0"
                                    Height="18"
                                    Kind="FileDocument"
                                    Margin="0,0,10,0"
                                    Width="18" />

                                <TextBlock
                                    FontSize="12"
                                    Foreground="{DynamicResource ForegroundColorBrush}"
                                    Grid.Column="1">
                                    <Run Text="{Binding Localization.ItemsToCompress, Mode=OneWay}" />
                                    <Run Text=": " />
                                    <Run FontWeight="Bold" Text="{Binding FilesToAdd.Count, Mode=OneWay}" />
                                </TextBlock>
                            </Grid>

                            <Grid Margin="0,5,0,0" Visibility="{Binding IsPasswordEnabled, Mode=OneWay, Converter={markupExtensions:Converters Converter=BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <materialIcons:MaterialIcon
                                    Foreground="{DynamicResource PrimaryColorBrush}"
                                    Grid.Column="0"
                                    Height="18"
                                    Kind="LockCheck"
                                    Margin="0,0,10,0"
                                    Width="18" />

                                <TextBlock
                                    FontSize="12"
                                    Foreground="{DynamicResource ForegroundColorBrush}"
                                    Grid.Column="1">
                                    <Run Text="{Binding Localization.PasswordProtection, Mode=OneWay}" />
                                    <Run Text=": " />
                                    <Run
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource PrimaryColorBrush}"
                                        Text="{Binding Localization.Enabled, Mode=OneWay}" />
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!--  Bottom Buttons  -->
        <Border
            Background="{DynamicResource BackgroundColorBrush}"
            BorderBrush="{DynamicResource ForegroundColorBrush}"
            BorderThickness="0,1,0,0"
            Grid.Row="2"
            Padding="20,15">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Background="{DynamicResource PrimaryColorBrush}"
                    Command="{Binding CreateZipCommand}"
                    Foreground="{DynamicResource ForegroundColorBrush}"
                    IsEnabled="{Binding FilesToAdd.Count, Mode=OneWay, Converter={markupExtensions:Converters Converter=CountToBooleanConverter}}"
                    Style="{StaticResource SzButton}"
                    ToolTip="{Binding Localization.CreateArchiveTooltip, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal">
                        <materialIcons:MaterialIcon
                            Foreground="{DynamicResource ForegroundColorBrush}"
                            Height="20"
                            Kind="ArchiveAdd"
                            Margin="0,0,10,0"
                            Width="20" />
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource ForegroundColorBrush}"
                            Text="{Binding Localization.CreateArchive, Mode=OneWay}" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>