<Window
    AllowsTransparency="True"
    Background="{DynamicResource BackgroundColorBrush}"
    DataContext="{markupExtensions:ResolveViewAndViewModel}"
    Height="380"
    Icon="{StaticResource ApplicationIcon}"
    MouseLeftButtonDown="ExtractArchiveView_OnMouseLeftButtonDown"
    Title="{Binding Localization.Extract}"
    Width="800"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    d:DataContext="{d:DesignInstance viewModels:ExtractArchiveViewModel}"
    mc:Ignorable="d"
    x:Class="SolidZip.Views.ExtractArchiveView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:icons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:local="clr-namespace:SolidZip.Views"
    xmlns:markupExtensions="clr-namespace:SolidZip.Views.MarkupExtensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:SolidZip.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto, Auto, Auto, *, Auto">
        <!--  Application's Title bar  -->

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Title and Icon area  -->
            <StackPanel
                Grid.Column="0"
                HorizontalAlignment="Left"
                Orientation="Horizontal"
                VerticalAlignment="Center">

                <Image
                    Margin="4,3,0,0"
                    Source="{Binding Icon, RelativeSource={RelativeSource AncestorType=Window}}"
                    Width="{StaticResource IconWidth}" />
                <TextBlock
                    FontFamily="{StaticResource BricolageGrotesque}"
                    FontSize="15"
                    Foreground="{DynamicResource ForegroundColorBrush}"
                    Margin="3,10,0,0"
                    Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" />

            </StackPanel>

            <!--  Buttons area  -->
            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                VerticalAlignment="Top">

                <!--  Minimize button  -->
                <Button
                    Click="Minimize"
                    Content="{icons:MaterialIconExt Kind=Minimize}"
                    Padding="2"
                    Style="{DynamicResource SzIconButton}"
                    Width="{StaticResource TitleBarIconsWidth}" />

                <!--  Maximize button  -->
                <Button
                    Click="Restore"
                    Content="{icons:MaterialIconExt Kind=Maximize}"
                    Padding="2"
                    Style="{DynamicResource SzIconButton}"
                    Width="{StaticResource TitleBarIconsWidth}" />

                <!--  Close button  -->
                <Button
                    Click="Close"
                    Content="{icons:MaterialIconExt Kind=Close}"
                    Padding="2"
                    Width="{StaticResource TitleBarIconsWidth}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource SzIconButton}" TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryColorBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <TextBlock
            Grid.Row="1"
            Margin="30,17,0,0"
            Style="{DynamicResource SzTextBlockLabel}"
            Text="{Binding Localization.SelectFolderToExtract}" />
        <Grid
            ColumnDefinitions="Auto, *, Auto"
            Grid.Row="2"
            Margin="0,2,0,0"
            MaxHeight="60"
            VerticalAlignment="Top">

            <icons:MaterialIcon
                Foreground="{DynamicResource ForegroundColorBrush}"
                Grid.Column="0"
                Height="30"
                Kind="Folder"
                Margin="10,0,0,0"
                VerticalAlignment="Center"
                Width="30" />

            <TextBox
                FontSize="15"
                Grid.Column="1"
                Margin="10,0,5,0"
                MaxHeight="40"
                Style="{StaticResource SzTextBox}"
                Text="{Binding ExtractPath}"
                VerticalAlignment="Center"
                x:Name="PathTextBox" />

            <Button
                Command="{Binding GetExtractPathFromWindowsExplorerCommand}"
                Content="..."
                Grid.Column="2"
                Height="{Binding Height, ElementName=PathTextBox}"
                Margin="0,0,10,0"
                MaxHeight="40"
                Style="{StaticResource SzButton}"
                VerticalAlignment="Center" />
        </Grid>

        <Grid
            ColumnDefinitions="*, *"
            Grid.Row="3"
            Margin="10,10,0,0">

            <Border
                BorderBrush="{DynamicResource ForegroundColorBrush}"
                BorderThickness="0,1,0,0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="4,-6,4,0" />

            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding PreserveAttributes}" Style="{StaticResource SzCheckBox}" />
                    <TextBlock Style="{StaticResource SzTextBlockLabel}" Text="{Binding Localization.PreserveAttributes}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding PreserveTime}" Style="{StaticResource SzCheckBox}" />
                    <TextBlock Style="{StaticResource SzTextBlockLabel}" Text="{Binding Localization.PreserveTime}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding ExtractFullPath}" Style="{StaticResource SzCheckBox}" />
                    <TextBlock Style="{StaticResource SzTextBlockLabel}" Text="{Binding Localization.ExtractFullPath}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding Override}" Style="{StaticResource SzCheckBox}" />
                    <TextBlock Style="{StaticResource SzTextBlockLabel}" Text="{Binding Localization.OverrideFiles}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding CreateDirectory}" Style="{StaticResource SzCheckBox}" />
                    <TextBlock Style="{StaticResource SzTextBlockLabel}" Text="{Binding Localization.CreateDirectoryForArchive}" />
                </StackPanel>
                <TextBlock
                    Margin="5,5,0,5"
                    Style="{StaticResource SzTextBlockLabel}"
                    Text="{Binding Localization.OutputArchiveDirectoryName}"
                    Visibility="{Binding CreateDirectory, Converter={markupExtensions:Converters Converter=BooleanToVisibilityConverter}}" />
                <StackPanel Orientation="Horizontal" Visibility="{Binding CreateDirectory, Converter={markupExtensions:Converters Converter=BooleanToVisibilityConverter}}">
                    <icons:MaterialIcon
                        Foreground="{DynamicResource ForegroundColorBrush}"
                        Grid.Column="0"
                        Height="23"
                        Kind="Folder"
                        Margin="0,0,5,0"
                        VerticalAlignment="Center"
                        Width="23" />
                    <TextBox Style="{DynamicResource SzTextBox}" Text="{Binding ExtractedArchiveDirectoryName}" />
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="0,10,0,0">
                <TextBlock Style="{StaticResource SzTextBlockLabel}" Text="{Binding Localization.Password}" />
                <StackPanel Orientation="Horizontal">
                    <icons:MaterialIcon
                        Foreground="{DynamicResource ForegroundColorBrush}"
                        Kind="PasswordAdd"
                        Margin="10,0" />
                    <TextBox
                        MaxWidth="200"
                        MinWidth="100"
                        Style="{StaticResource SzTextBox}" />
                </StackPanel>
            </StackPanel>
        </Grid>
        <Button
            Command="{Binding ExtractArchiveCommand}"
            Grid.Row="4"
            Margin="250,0,20,5"
            Style="{StaticResource SzButton}">
            <Button.Content>
                <StackPanel Orientation="Horizontal">
                    <icons:MaterialIcon Kind="ArchiveArrowDown" x:Name="ExtractIcon" />
                    <TextBlock
                        FontSize="20"
                        Style="{StaticResource SzTextBlockLabel}"
                        Text="{Binding Localization.Extract}" />
                </StackPanel>
            </Button.Content>
        </Button>
    </Grid>
</Window>
